<Application xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
x:Class="DMVideoPlayer.App"
RequestedThemeVariant="Default">
<Application.Styles>
        <FluentTheme />
        
        <!-- Style pour les boutons de lecture (Play/Pause/Stop) -->
        <Style Selector="Button.playback-button">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        
        <!-- État au survol pour les boutons de lecture -->
        <Style Selector="Button.playback-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="BorderBrush" Value="#5DADE2"/>
        </Style>
        
        <!-- État pressé pour les boutons de lecture -->
        <Style Selector="Button.playback-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#2E5F8F"/>
            <Setter Property="BorderBrush" Value="#4A90E2"/>
        </Style>
        
        <!-- Style pour les boutons de sélection (OUT, AUD, SUB) -->
        <Style Selector="Button.selection-button">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        
        <!-- État au survol -->
        <Style Selector="Button.selection-button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="BorderBrush" Value="#5DADE2"/>
        </Style>
        
        <!-- État pressé -->
        <Style Selector="Button.selection-button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#2E5F8F"/>
            <Setter Property="BorderBrush" Value="#4A90E2"/>
        </Style>
        
        <!-- État désactivé -->
        <Style Selector="Button.selection-button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="Foreground" Value="#6A6A6A"/>
        </Style>
        
        <!-- Style pour le slider de balance : afficher un trait horizontal complet -->
        <!-- Partie gauche du thumb : cachée -->
        <Style Selector="Slider.balance-slider /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Background" Value="#5A5A5A"/>
            <Setter Property="Height" Value="3"/>
        </Style>
        
        <!-- Partie droite du thumb : trait gris visible -->
        <Style Selector="Slider.balance-slider /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Background" Value="#5A5A5A"/>
            <Setter Property="Height" Value="3"/>
        </Style>
        
        <!-- Style du thumb (rond bleu) -->
        <Style Selector="Slider.balance-slider:horizontal /template/ Thumb">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="BorderBrush" Value="#4A90E2"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
        </Style>
        
        <!-- Style du slider de balance quand il est désactivé -->
        <Style Selector="Slider.balance-slider:disabled /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        
        <Style Selector="Slider.balance-slider:disabled /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        
        <Style Selector="Slider.balance-slider:disabled /template/ Thumb">
            <Setter Property="Background" Value="#6A6A6A"/>
            <Setter Property="BorderBrush" Value="#6A6A6A"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        
        <!-- Style pour les sliders de position et volume : thumb plus petit -->
        <Style Selector="Slider:horizontal /template/ Thumb">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
        </Style>
    </Application.Styles>
</Application>
